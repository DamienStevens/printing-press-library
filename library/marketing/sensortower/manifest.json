{
  "manifest_version": "0.3",
  "name": "sensortower-pp-mcp",
  "display_name": "Sensor Tower",
  "version": "0.1.0",
  "description": "Every free Sensor Tower ranking, plus the rank history the dashboard forgets the moment you close the tab.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/sensortower-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/sensortower-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
