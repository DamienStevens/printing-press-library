    {
      "name": "domains_create",
      "description": "Create a managed domain. Required: name. Optional: gtdEnabled, soaId, templateId (plus 3 more). Returns the new Domain.",
      "method": "POST",
      "path": "/dns/managed",
      "params": [
        {
          "name": "name",
          "type": "string",
          "location": "body",
          "description": "Domain name to create, e.g. example.com",
          "required": true
        },
        {
          "name": "gtdEnabled",
          "type": "bool",
          "location": "body",
          "description": "Enable Global Traffic Director (GTD)"
        },
        {
          "name": "soaId",
          "type": "string",
          "location": "body",
          "description": "SOA record id to attach"
        },
        {
          "name": "templateId",
          "type": "string",
          "location": "body",
          "description": "Template id to provision records from"
        },
        {
          "name": "vanityId",
          "type": "string",
          "location": "body",
          "description": "Vanity DNS configuration id"
        },
        {
          "name": "transferAclId",
          "type": "string",
          "location": "body",
          "description": "Transfer ACL id"
        },
        {
          "name": "folderId",
          "type": "string",
          "location": "body",
          "description": "Folder id to place the domain in"
