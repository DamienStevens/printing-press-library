{
  "api_name": "dnsmadeeasy",
  "base_url": "https://api.dnsmadeeasy.com/V2.0",
  "description": "Every DNS Made Easy operation, plus a local record store for cross-zone search, drift detection, and 'where is this IP used' — instant and offline.",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "api_key",
    "header": "x-dnsme-apiKey",
    "format": "{DNSMADEEASY_API_KEY}",
    "in": "header",
    "env_vars": [
      "DNSMADEEASY_API_KEY",
      "DNSMADEEASY_API_SECRET"
    ],
    "env_var_specs": [
      {
        "name": "DNSMADEEASY_API_KEY",
        "kind": "per_call",
        "required": true,
        "sensitive": true,
        "inferred": true
      },
      {
        "name": "DNSMADEEASY_API_SECRET",
        "kind": "per_call",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ]
  },
  "required_headers": [],
