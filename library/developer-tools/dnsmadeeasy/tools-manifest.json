    {
      "name": "records_create",
      "description": "Create a DNS record in a domain. Required: domainId, name, type, value. Optional: ttl (default: 1800), gtdLocation, mxLevel (plus 11 more). Returns the new Record.",
      "method": "POST",
      "path": "/dns/managed/{domainId}/records",
      "params": [
        {
          "name": "domainId",
          "type": "string",
          "location": "path",
          "description": "Numeric domain id",
          "required": true
        },
        {
          "name": "name",
          "type": "string",
          "location": "body",
          "description": "Record name / host label (use empty string or @ for apex)",
          "required": true
        },
        {
          "name": "type",
          "type": "string",
          "location": "body",
          "description": "Record type: A, AAAA, CNAME, MX, TXT, SRV, NS, PTR, SPF, CAA, ANAME, HTTPRED",
          "required": true
        },
        {
          "name": "value",
          "type": "string",
          "location": "body",
          "description": "Record value / target (IP, hostname, text, etc.)",
          "required": true
        },
        {
          "name": "ttl",
          "type": "int",
          "location": "body",
          "description": "Time to live in seconds"
        },
        {
          "name": "gtdLocation",
          "type": "string",
          "location": "body",
          "description": "GTD location: DEFAULT, US_EAST, US_WEST, EUROPE, ASIA_PAC, OCEANIA, SOUTH_AMERICA"
        },
        {
          "name": "mxLevel",
          "type": "int",
          "location": "body",
          "description": "MX preference (MX records)"
        },
        {
          "name": "priority",
          "type": "int",
          "location": "body",
          "description": "Priority (SRV records)"
        },
        {
          "name": "weight",
          "type": "int",
          "location": "body",
          "description": "Weight (SRV records)"
        },
        {
          "name": "port",
          "type": "int",
          "location": "body",
          "description": "Port (SRV records)"
        },
        {
          "name": "dynamicDns",
          "type": "bool",
          "location": "body",
          "description": "Mark record as dynamic DNS"
        },
        {
          "name": "password",
          "type": "string",
          "location": "body",
          "description": "Dynamic DNS password"
        },
        {
          "name": "description",
          "type": "string",
          "location": "body",
          "description": "Free-text description"
        },
        {
          "name": "keywords",
          "type": "string",
          "location": "body",
          "description": "Keywords (HTTPRED records)"
        },
        {
          "name": "redirectType",
          "type": "string",
          "location": "body",
          "description": "Redirect type (HTTPRED records)"
        },
        {
          "name": "hardLink",
          "type": "bool",
          "location": "body",
          "description": "Hard link (HTTPRED records)"
        },
        {
          "name": "caaType",
          "type": "string",
          "location": "body",
          "description": "CAA type: issue, issuewild, iodef"
        },
        {
          "name": "issuerCritical",
          "type": "int",
          "location": "body",
          "description": "CAA issuer critical flag (0 or 1)"
        }
      ]
    },
